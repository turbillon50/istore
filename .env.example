# ===== iStore Pro — Variables de entorno =====

# Neon Postgres (ya configurada en Vercel)
DATABASE_URL=

# Clerk — REQUERIDAS para activar autenticación real.
# Sin estas dos, la app corre en modo demo (sin login).
# Crear app en https://dashboard.clerk.com con dominio i-store.shop
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Opcional (webhook user.created → DB, estándar MyMomentum)
CLERK_WEBHOOK_SIGNING_SECRET=

# ===== Liga-llave (acceso instalable a administración) =====
# La liga ES la llave: https://i-store.shop/<ADMIN_LINK_TOKEN> instala una
# cookie de acceso de 1 año y abre el panel sin login. NUNCA commitear valores;
# solo en env de Vercel y en el brain (name=accesos-admin-istore).
ADMIN_LINK_TOKEN=
STAFF_LINK_TOKEN=

# ===== Resend (correos transaccionales) =====
# Verificar dominio en https://resend.com/domains (DNS: SPF + DKIM + MX).
RESEND_API_KEY=
# Remitente con dominio propio verificado (ej. no-reply@i-store.shop).
EMAIL_FROM="iStore <no-reply@i-store.shop>"

# ===== Seed =====
# SEED_DEMO=true siembra datos demo solo si las tablas están vacías.
SEED_DEMO=
