# ============================================================
# iStore Pro — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://istore.pro
NODE_ENV=development

# ─── Database (Neon Postgres) ─────────────────────────────────
# Pooled connection — used by Prisma at runtime (serverless)
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx.us-east-2.aws.neon.tech/istore?sslmode=require&pgbouncer=true&connection_limit=1

# Direct connection — used for Prisma migrations
DIRECT_URL=postgresql://USER:PASSWORD@ep-xxx.us-east-2.aws.neon.tech/istore?sslmode=require

# ─── Clerk (Authentication) ───────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# Clerk redirect paths
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/iniciar-sesion
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/registro
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/cuenta
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/cuenta

# ─── Stripe ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── MercadoPago ─────────────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=APP_USR-...
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=APP_USR-...
MERCADOPAGO_WEBHOOK_SECRET=...
# Your MercadoPago application ID (numeric)
MERCADOPAGO_APP_ID=...

# ─── Resend (Email) ──────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM=iStore Pro <noreply@istore.pro>

# ─── Cloudinary (Media) ──────────────────────────────────────
CLOUDINARY_CLOUD_NAME=...
CLOUDINARY_API_KEY=...
CLOUDINARY_API_SECRET=...
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=...

# ─── n8n (Workflow Automation) ───────────────────────────────
N8N_WEBHOOK_URL=https://n8n.yourdomain.com/webhook
N8N_API_KEY=...

# ─── Analytics ───────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-...
NEXT_PUBLIC_META_PIXEL=...
NEXT_PUBLIC_TIKTOK_PIXEL=...

# ─── Google ──────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=AIza...

# ─── AI Providers ────────────────────────────────────────────
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...
OPENROUTER_API_KEY=sk-or-...
