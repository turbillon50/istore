# ===== iStore Pro — Variables de entorno =====

# Neon Postgres (ya configurada en Vercel)
DATABASE_URL=

# Clerk — REQUERIDAS para activar autenticación real.
# Sin estas dos, la app corre en modo demo (sin login).
# Crear app en https://dashboard.clerk.com con dominio i-store.shop
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Opcional (webhook user.created → DB, estándar MyMomentum)
CLERK_WEBHOOK_SIGNING_SECRET=
